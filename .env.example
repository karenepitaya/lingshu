# 灵枢·五觉养生阁 - 环境变量配置

# OpenAI 兼容 API 配置
# 如果使用 OpenAI 官方 API:
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1

# 如果使用其他兼容 API (如小米 MiMo):
# OPENAI_API_KEY=your-key-here
# OPENAI_BASE_URL=https://api.your-provider.com/v1

# 模型名称
MODEL_NAME=mimo-v2.5

# Coze 工作流配置
COZE_BASE_URL=https://api.coze.cn

# 饮食模块 (diet) - workflow
COZE_DIET_WORKFLOW_ID=your_diet_workflow_id
COZE_DIET_TOKEN=pat_your_diet_token

# 运动模块 (exercise) - workflow
COZE_EXERCISE_WORKFLOW_ID=your_exercise_workflow_id
COZE_EXERCISE_TOKEN=pat_your_exercise_token

# 心理模块 (mental) - workflow
COZE_MENTAL_WORKFLOW_ID=your_mental_workflow_id
COZE_MENTAL_TOKEN=pat_your_mental_token

# 养生模块 (wellness) - workflow
COZE_WELLNESS_WORKFLOW_ID=your_wellness_workflow_id
COZE_WELLNESS_TOKEN=pat_your_wellness_token

# 惊喜模块 (surprise) - chatflow
COZE_SURPRISE_WORKFLOW_ID=your_surprise_workflow_id
COZE_SURPRISE_TOKEN=pat_your_surprise_token
